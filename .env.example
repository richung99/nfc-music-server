# Copy this file to .env and fill in your values
# Never commit .env to git

# Last.fm API key — get one at https://www.last.fm/api/account/create
LASTFM_KEY=your_lastfm_api_key_here

# Genius API token — get one at https://genius.com/api-clients
GENIUS_TOKEN=your_genius_token_here

# Tailscale hostname — e.g. mymachine.tail1234.ts.net
TAILSCALE_HOSTNAME=your-machine.tail1234.ts.net

# Ollama models
OLLAMA_MODEL=qwen2.5:14b
NAMING_MODEL=gemma3:12b
